+                                      target->url.url,
+                                      &target->ssl_name);
+    ngx_rtmp_relay_push(s, &push_pull_ctx->name, target);
+    return;
+
+error:
+    ngx_log_error(NGX_LOG_ERR, s->connection->log, 0,
+                  "error processing resolver response");
+    ngx_rtmp_finalize_session(s);
