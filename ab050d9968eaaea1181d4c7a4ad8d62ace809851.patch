+#endif
+
+    target->url.naddrs = naddrs;
+    target->url.addrs = ngx_pcalloc(s->connection->pool,
+                                    sizeof(ngx_addr_t) * naddrs);
+    if (target->url.addrs == NULL) {
+        goto error;
+    }
+
+    for (i = 0; i < naddrs; i++) {
+        sa = ngx_pcalloc(s->connection->pool, addrs[i].socklen);
+        if (sa == NULL) {
