+ngx_rtmp_notify_resolve_handler(ngx_resolver_ctx_t *ctx)
+{
+    ngx_rtmp_notify_push_pull_ctx_t            *push_pull_ctx;
+    ngx_rtmp_session_t                         *s;
+    ngx_rtmp_relay_target_t                    *target;
+    ngx_uint_t                                  naddrs, i;
+    ngx_resolver_addr_t                        *addrs;
