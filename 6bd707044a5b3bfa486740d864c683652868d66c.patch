From 6bd707044a5b3bfa486740d864c683652868d66c Mon Sep 17 00:00:00 2001
From: Emmanuel Mathi-Amorim <manny@amorim.ca>
Date: Sun, 8 May 2022 09:39:28 -0400
Subject: [PATCH] Switch to sending rtmps as the protocol to rtmps relay
 targets

---
 ngx_rtmp_relay_module.c | 20 ++++++++++++++++++--
 ngx_rtmp_relay_module.h |  1 +
 2 files changed, 19 insertions(+), 2 deletions(-)

diff --git a/ngx_rtmp_relay_module.c b/ngx_rtmp_relay_module.c
index 8c05acf09..7ab6ac077 100644
--- a/ngx_rtmp_relay_module.c
+++ b/ngx_rtmp_relay_module.c
@@ -491,6 +491,20 @@ ngx_rtmp_relay_create_connection(ngx_rtmp_conf_ctx_t *cctx, ngx_str_t* name,
         goto clear;
     }
 
+#if (NGX_RTMP_SSL)
+
+    if (target->is_rtmps) {
+        ngx_str_set(&rctx->proto, "rtmps://");
+    } else {
+        ngx_str_set(&rctx->proto, "rtmp://");
+    }
+
+#else
+
+    ngx_str_set(&rctx->proto, "rtmp://");
+
+#endif 
+
     rctx->tag = target->tag;
     rctx->data = target->data;
 
@@ -696,6 +710,8 @@ ngx_rtmp_relay_create_local_ctx(ngx_rtmp_session_t *s, ngx_str_t *name,
         return NULL;
     }
 
+    ngx_str_set(&ctx->proto, "rtmp://");
+
     return ctx;
 }
 
@@ -1018,14 +1034,14 @@ ngx_rtmp_relay_send_connect(ngx_rtmp_session_t *s)
         out_cmd[1].data = ctx->tc_url.data;
         out_cmd[1].len  = ctx->tc_url.len;
     } else {
-        len = sizeof("rtmp://") - 1 + ctx->url.len +
+        len = ctx->proto.len + ctx->url.len +
             sizeof("/") - 1 + ctx->app.len;
         p = ngx_palloc(s->connection->pool, len);
         if (p == NULL) {
             return NGX_ERROR;
         }
         out_cmd[1].data = p;
-        p = ngx_cpymem(p, "rtmp://", sizeof("rtmp://") - 1);
+        p = ngx_cpymem(p, ctx->proto.data, ctx->proto.len);
 
         url_len = ctx->url.len;
         url_end = ngx_strlchr(ctx->url.data, ctx->url.data + ctx->url.len, '/');
diff --git a/ngx_rtmp_relay_module.h b/ngx_rtmp_relay_module.h
index dc8adfe3c..8a10d419a 100644
--- a/ngx_rtmp_relay_module.h
+++ b/ngx_rtmp_relay_module.h
@@ -46,6 +46,7 @@ typedef struct ngx_rtmp_relay_ctx_s ngx_rtmp_relay_ctx_t;
 
 struct ngx_rtmp_relay_ctx_s {
     ngx_str_t                       name;
+    ngx_str_t                       proto;
     ngx_str_t                       url;
     ngx_log_t                       log;
     ngx_rtmp_session_t             *session;
